# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly LF for JS/web source files
*.mjs text eol=lf
*.js  text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
